{
  "name": "alex-slack-bot",
  "version": "1.0.0",
  "description": "Minimal production-structured Slack Bot backend for Alex",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:client": "cd client && npm install && npm run build",
    "dev:client": "cd client && npm run dev"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@vendia/serverless-express": "^4.12.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  }
}
